# 鉴权 —— Header: X-API-Key
# 留空 = 关闭鉴权（本机集成场景默认）。配上任意非空值即启用静态 Key 校验。
EFAPIAO_API_KEY=

# HTTP 服务监听地址
# 本机集成：127.0.0.1（默认）；对外开放：0.0.0.0
EFAPIAO_HOST=127.0.0.1
EFAPIAO_PORT=8000

# 上传文件大小上限（字节），默认 10 MB
EFAPIAO_MAX_FILE_BYTES=10485760

# Webhook 透传超时（秒）
EFAPIAO_FORWARD_TIMEOUT=5

# 是否允许 HTTP 透传地址（生产环境保持 false，强制 HTTPS）
EFAPIAO_FORWARD_ALLOW_HTTP=false

# OCR vendor：none（默认关闭）/ cnocr / http / tencent
# cnocr 需安装可选依赖：pip install -e ".[ocr-cnocr]"
EFAPIAO_OCR_VENDOR=none

# CnOCR vendor：纯 CPU / 多架构 Docker 默认建议 ONNX 小模型
EFAPIAO_CNOCR_DET_MODEL=ch_PP-OCRv5_det
EFAPIAO_CNOCR_REC_MODEL=doc-densenet_lite_136-gru
EFAPIAO_CNOCR_DET_BACKEND=onnx
EFAPIAO_CNOCR_REC_BACKEND=onnx

# 第三方 HTTP OCR vendor
EFAPIAO_OCR_HTTP_URL=
EFAPIAO_OCR_HTTP_HEADERS=
EFAPIAO_OCR_HTTP_TIMEOUT=10
# 仅本地调试第三方 OCR mock 服务时设 true；生产保持 false，强制 HTTPS
EFAPIAO_OCR_HTTP_ALLOW_HTTP=false

# 腾讯云 OCR vendor
# 鉴权优先级：源码 context override > 凭据文件 > 环境变量
# 也兼容腾讯云标准环境变量：TENCENTCLOUD_SECRET_ID / TENCENTCLOUD_SECRET_KEY / TENCENTCLOUD_TOKEN
EFAPIAO_TENCENT_SECRET_ID=
EFAPIAO_TENCENT_SECRET_KEY=
EFAPIAO_TENCENT_TOKEN=
EFAPIAO_TENCENT_CREDENTIALS_FILE=
EFAPIAO_TENCENT_REGION=ap-guangzhou
EFAPIAO_TENCENT_OCR_ENDPOINT=ocr.tencentcloudapi.com
EFAPIAO_TENCENT_OCR_ACTION=RecognizeGeneralInvoice
EFAPIAO_TENCENT_OCR_VERSION=2018-11-19
EFAPIAO_TENCENT_OCR_TIMEOUT=10
