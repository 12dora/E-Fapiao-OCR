# 鉴权 —— Header: X-API-Key
# 留空 = 关闭鉴权（本机集成场景默认）。配上任意非空值即启用静态 Key 校验。
EFAPIAO_API_KEY=

# HTTP 服务监听地址
# 本机集成：127.0.0.1（默认）；对外开放：0.0.0.0
EFAPIAO_HOST=127.0.0.1
EFAPIAO_PORT=8000

# 上传文件大小上限（字节），默认 10 MB
EFAPIAO_MAX_FILE_BYTES=10485760

# Webhook 透传超时（秒）
EFAPIAO_FORWARD_TIMEOUT=5

# 是否允许 HTTP 透传地址（生产环境保持 false，强制 HTTPS）
EFAPIAO_FORWARD_ALLOW_HTTP=false
